# ============================================================
# DagsHub Configuration for MLflow Remote Tracking
# ============================================================
#
# How to obtain credentials:
# 1. Go to: https://dagshub.com
# 2. Login/Signup with GitHub
# 3. Create new repository: "employee-attrition"
# 4. Go to Settings > Access Tokens
# 5. Generate Personal Token (scope: read, write)
# 6. Copy username and token below
#
# ============================================================

# Your DagsHub username
# Example: carissaokt
DAGSHUB_USER_NAME=your_dagshub_username

# Your DagsHub Personal Access Token (keep SECRET!)
# Example: abc123def456ghi789jkl012
DAGSHUB_USER_TOKEN=your_dagshub_token

# MLflow Tracking URI (auto-syncs metrics to DagsHub)
# Format: https://dagshub.com/<USERNAME>/<REPO>.mlflow
# Example: https://dagshub.com/carissaokt/employee-attrition.mlflow
MLFLOW_TRACKING_URI=https://dagshub.com/your_username/employee-attrition.mlflow

# MLflow Experiment Name (optional, default: Employee Attrition)
MLFLOW_EXPERIMENT_NAME=Employee Attrition

# ============================================================
# Setup Instructions
# ============================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Edit .env and replace placeholders with your credentials
#
# 3. Test connection:
#    python test_dagshub.py
#
# 4. Run training (will auto-sync to DagsHub):
#    python model/train.py
#
# 5. View on DagsHub:
#    https://dagshub.com/<YOUR_USERNAME>/employee-attrition
#
# ============================================================

# SECURITY WARNING:
# - NEVER commit .env file to git!
# - .env is added to .gitignore for protection
# - Keep DAGSHUB_USER_TOKEN secret!

